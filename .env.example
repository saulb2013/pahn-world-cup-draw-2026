# Copy to .env.local for local dev, and set the same as Environment Variables
# on Vercel. None of these are required to run the app locally (it falls back to
# local-only mode), but they enable the shared + automatic features.

# Live results feed — get a free key at https://www.football-data.org/client/register
# When set, finished group results are pulled in automatically (no manual entry).
FOOTBALL_DATA_KEY=

# Admin password (must match ADMIN_KEY in src/config.js). Visitors using
# ?admin=<this> can run the draw and edit scores; everyone else is read-only.
ADMIN_KEY=elucidate

# Shared database (auto-injected by Vercel when you add Upstash for Redis).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
